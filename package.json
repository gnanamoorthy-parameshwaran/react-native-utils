{
    "name": "@gnanamoorthy/react-native-utils",
    "version": "0.1.0",
    "description": "Used to store the common utilities for react native app",
    "main": "./lib/module/index.js",
    "types": "./lib/typescript/src/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.tsx",
            "types": "./lib/typescript/src/index.d.ts",
            "default": "./lib/module/index.js"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "react-native-utils": "./lib/cli/scripts/cli.js"
    },
    "files": [
        "src",
        "lib",
        "!**/__tests__",
        "!**/__fixtures__",
        "!**/__mocks__",
        "!**/.*"
    ],
    "scripts": {
        "example": "yarn workspace react-native-utils-example",
        "test": "jest",
        "typecheck": "tsc",
        "lint": "eslint \"**/*.{js,ts,tsx}\"",
        "clean": "del-cli lib",
        "build:cli": "tsc -p tsconfig.cli.json && chmod +x lib/cli/scripts/cli.js",
        "prepare": "bob build && npm run build:cli",
        "release": "release-it --only-version"
    },
    "keywords": [
        "react-native",
        "ios",
        "android"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gnanamoorthy-parameshwaran/react-native-utils.git"
    },
    "author": "Gnanamoorthy Parameshwaran <gnanamoorthy.dev@gmail.com> (https://github.com/gnanamoorthy-parameshwaran)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/gnanamoorthy-parameshwaran/react-native-utils/issues"
    },
    "homepage": "https://github.com/gnanamoorthy-parameshwaran/react-native-utils#readme",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/compat": "^1.3.2",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.35.0",
        "@evilmartians/lefthook": "^1.12.3",
        "@react-native-async-storage/async-storage": "^3.1.1",
        "@react-native-picker/picker": "^2.11.4",
        "@react-native/babel-preset": "0.81.1",
        "@react-native/eslint-config": "^0.81.1",
        "@react-navigation/native": "^7.3.4",
        "@release-it/conventional-changelog": "^10.0.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^26.1.0",
        "@types/react": "^19.1.12",
        "commitlint": "^19.8.1",
        "del-cli": "^6.0.0",
        "eslint": "^9.35.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "expo-document-picker": "^56.0.4",
        "expo-image-picker": "^56.0.18",
        "jest": "^29.7.0",
        "prettier": "^3.6.2",
        "react": "19.0.0",
        "react-native": "0.79.6",
        "react-native-builder-bob": "^0.40.13",
        "react-native-paper": "^5.15.3",
        "release-it": "^19.0.4",
        "typescript": "^5.9.2"
    },
    "peerDependencies": {
        "react": "*",
        "react-native": "*"
    },
    "workspaces": [
        "example"
    ],
    "packageManager": "yarn@3.6.1",
    "jest": {
        "preset": "react-native",
        "modulePathIgnorePatterns": [
            "<rootDir>/example/node_modules",
            "<rootDir>/lib/"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "release-it": {
        "git": {
            "commitMessage": "chore: release ${version}",
            "tagName": "v${version}"
        },
        "npm": {
            "publish": true
        },
        "github": {
            "release": true
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "preset": {
                    "name": "angular"
                }
            }
        }
    },
    "prettier": {
        "quoteProps": "consistent",
        "singleQuote": true,
        "useTabs": false,
        "arrowParens": "avoid",
        "bracketSameLine": true,
        "bracketSpacing": false,
        "trailingComma": "all",
        "printWidth": 150,
        "tabWidth": 4
    },
    "react-native-builder-bob": {
        "source": "src",
        "output": "lib",
        "exclude": "**/{__tests__,__fixtures__,__mocks__,generateAPI}/**",
        "targets": [
            [
                "module",
                {
                    "esm": true
                }
            ],
            [
                "typescript",
                {
                    "project": "tsconfig.build.json"
                }
            ]
        ]
    }
}
