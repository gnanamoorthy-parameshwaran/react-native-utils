{
  "compilerOptions": {
    "rootDir": "src/packages/clientGenerator",
    "outDir": "lib/cli",
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "ES2020",
    "lib": ["ES2020"],
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/packages/clientGenerator/**/*.ts"]
}
