{
    "compilerOptions": {
        "rootDir": "src/packages/generateAPI",
        "outDir": "lib/cli",
        "module": "node16",
        "moduleResolution": "node16",
        "target": "ES2020",
        "lib": ["ES2020"],
        "noEmit": false,
        "declaration": false,
        "sourceMap": false,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "verbatimModuleSyntax": false
    },
    "include": ["src/packages/generateAPI/**/*.ts"]
}
